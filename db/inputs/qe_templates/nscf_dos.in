&CONTROL
    calculation = 'nscf'
    prefix      = '${PREFIX}'    ! MUST match SCF prefix!
    outdir      = './tmp'
    pseudo_dir  = './pseudo'
/
&SYSTEM
    ibrav       = 0
    nat         = ${NAT}
    ntyp        = ${NTYP}
    ecutwfc     = 60.0
    ecutrho     = 480.0
    occupations = 'tetrahedra_opt'    ! For DOS, use tetrahedra
    ! Remove smearing/degauss for tetrahedra
/
&ELECTRONS
    conv_thr    = 1.0d-10
/

K_POINTS automatic
${KGRID_DENSE} 0 0 0

! Dense k-grid: typically 2x the SCF grid
! After NSCF: run dos.x and projwfc.x for PDOS
